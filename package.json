{
  "name": "screenpipe-ui",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/remoun/screenpipe-ui"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "cli": "bun run packages/cli/src/index.ts",
    "tui": "bun run packages/tui/src/index.tsx",
    "web": "bun run --cwd packages/web vite dev",
    "build": "bun run --filter '*' build",
    "test": "bun test --recursive"
  }
}
