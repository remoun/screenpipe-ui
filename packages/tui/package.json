{
  "name": "@screenpipe-ui/tui",
  "version": "0.1.5",
  "description": "Interactive TUI for screenpipe. Part of screenpipe-ui — also includes CLI and web interfaces.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "screenpipe-tui": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "test": "bun test",
    "dev": "bun run src/index.tsx",
    "build": "tsup src/index.tsx --format esm --target node18 --clean && chmod +x dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/remoun/screenpipe-ui",
    "directory": "packages/tui"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@screenpipe-ui/core": "workspace:*",
    "@screenpipe-ui/react": "workspace:*",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3"
  }
}
